{
   "command": "discordrp.enable",
   "title": "enable (this workbench)",
   "category": "discordrp",
   "enablement": "workbenchState != empty"
},
{
   "command": "discordrp.disable",
   "title": "disable (this workbench)",
   "category": "discordrp",
   "enablement": "workbenchState != empty"
},
{
   "command": "discordrp.disable-tmp",
   "title": "disable (this workbench, until exit)",
   "category": "discordrp",
   "enablement": "workbenchState != empty"
},
{
   "command": "discordrp.run",
   "title": "run",
   "category": "discordrp",
   "enablement": "workbenchState != empty"
},
{
   "command": "discordrp.stop",
   "title": "stop",
   "category": "discordrp",
   "enablement": "workbenchState != empty"
}
