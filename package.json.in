dnl
{
   "name": "discordrp",
   "type": "module",
   "version": "0.1.0",
   "publisher": "barroit",
   "license": "GPL-3.0-or-later",
   "main": "build/entry.js",
   "engines": {
      "vscode": "^1.74.0"
   },
   "devDependencies": {
      "escape-string-regexp": "^5.0.0"
   },
   "activationEvents": [
      "onStartupFinished"
   ],
   "contributes": {
      "configuration": {
         "type": "object",
         "properties": {
include([[package/config.json]])dnl
         }
      },
      "commands": [
include([[package/cmd.json]])dnl
      ]
   },
   "displayName": "Discord Rich Presence with Git",
   "description": "Display repository and workbench status in rich presence",
   "icon": "images/negi.png",
   "categories": [
      "Other"
   ],
   "repository": {
      "type": "git",
      "url": "git+ssh://git@github.com:barroit/vsc-discordrp.git"
   }
}
